	local function cleanEffects(plr, mode)
		local char = plr.Character
		local lp = game.Players.LocalPlayer

		if char then
			if mode == "Player" or mode == "All" then
				local h = char:FindFirstChild("Highlight_0")
				if h then h:Destroy() end
				local b = char:FindFirstChild("StealBeam")
				if b then b:Destroy() end
				local a = char:FindFirstChild("StealAtt")
				if a then a:Destroy() end

				if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
					local old = lp.Character.HumanoidRootPart:FindFirstChild("To_" .. plr.Name)
					if old then old:Destroy() end
				end
			end

			if mode == "Base" or mode == "All" then
				local b2 = char:FindFirstChild("StealBeam2")
				if b2 then b2:Destroy() end
				local a2 = char:FindFirstChild("StealAtt2")
				if a2 then a2:Destroy() end

				for _, plot in pairs(workspace.Plots:GetChildren()) do
					local delivery = plot:FindFirstChild("DeliveryHitbox")
					if delivery then
						local old = delivery:FindFirstChild("To_" .. plr.Name .. "2")
						if old then old:Destroy() end
					end
				end
			end
		end
	end

	local function applyEffects(plr)
		local char = plr.Character
		local lp = game.Players.LocalPlayer
		if not char or not char:FindFirstChild("HumanoidRootPart") or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end

		local isStealing = plr:GetAttribute("Stealing")

		if states.EspPlayerStealing and isStealing then
			if not char:FindFirstChild("StealBeam") then
				local h = Instance.new("Highlight")
				h.Name = "Highlight_0"
				h.Parent = char

				local att0 = Instance.new("Attachment")
				att0.Name = "To_" .. plr.Name
				att0.Parent = lp.Character.HumanoidRootPart

				local att1 = Instance.new("Attachment")
				att1.Name = "StealAtt"
				att1.Parent = char.HumanoidRootPart

				local b = Instance.new("Beam")
				b.Name = "StealBeam"
				b.Attachment0 = att0
				b.Attachment1 = att1
				b.Width0, b.Width1 = 0.1, 0.1
				b.FaceCamera = true
				b.Parent = char
			end
		else
			cleanEffects(plr, "Player")
		end

		if states.EspPlayerStealingBase and isStealing then
			if not char:FindFirstChild("StealBeam2") then
				local targetPlot = nil
				for _, plot in pairs(workspace.Plots:GetChildren()) do
					local Data = items.reqdata:InvokeServer(plot.Name)
					if Data and Data.Owner == plr then
						targetPlot = plot
						break
					end
				end

				if targetPlot and targetPlot:FindFirstChild("DeliveryHitbox") then
					local att0 = Instance.new("Attachment")
					att0.Name = "To_" .. plr.Name .. "2"
					att0.Parent = targetPlot.DeliveryHitbox

					local att1 = Instance.new("Attachment")
					att1.Name = "StealAtt2"
					att1.Parent = char.HumanoidRootPart

					local b = Instance.new("Beam")
					b.Name = "StealBeam2"
					b.Attachment0 = att0
					b.Attachment1 = att1
					b.Width0, b.Width1 = 0.1, 0.1
					b.FaceCamera = true
					b.Parent = char
				end
			end
		else
			cleanEffects(plr, "Base")
		end
	end

