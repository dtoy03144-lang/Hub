			local RANGE = 20
			local UPDATE_RATE = 0.1

			local stored = {}

			Lighting.GlobalShadows = false
			Lighting.Brightness = 0

			pcall(function()
				game:GetService("UserGameSettings").SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
			end)

			local function disablePartShadows(obj)
				if obj:IsA("BasePart") then
					obj.CastShadow = false
				end
			end

			for _, v in ipairs(Workspace:GetDescendants()) do
				disablePartShadows(v)
			end

			Workspace.DescendantAdded:Connect(function(v)
				disablePartShadows(v)
			end)

			local function getPosition(obj)
				if obj:IsA("Model") then
					local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
					if pp then return pp.Position end
				elseif obj:IsA("BasePart") then
					return obj.Position
				end
				return nil
			end

			local function getCFrame(obj)
				if obj:IsA("Model") then
					local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
					if pp then return pp.CFrame end
				elseif obj:IsA("BasePart") then
					return obj.CFrame
				end
			end

			local function setCFrame(obj, cf)
				if not cf then return end

				if obj:IsA("Model") then
					if obj.PrimaryPart then
						obj:SetPrimaryPartCFrame(cf)
					else
						local p = obj:FindFirstChildWhichIsA("BasePart")
						if p then p.CFrame = cf end
					end
				elseif obj:IsA("BasePart") then
					obj.CFrame = cf
				end
			end

			local function valid(obj, char)
				if obj == char then return false end
				if obj:IsDescendantOf(char) then return false end
				if obj:IsA("Terrain") then return false end
				if obj.Name:lower():find("baseplate") then return false end

				return obj:IsA("Model") or obj:IsA("BasePart")
			end
			local player=game.Players.LocalPlayer
			local function update()
				local char = player.Character
				if not char then return end

				local root = char:FindFirstChild("HumanoidRootPart")
				if not root then return end

				local pos = root.Position

				for _, obj in ipairs(Workspace:GetChildren()) do
					if valid(obj, char) and not game.Players:GetPlayerFromCharacter(obj) then
						if  obj:GetAttribute("Index") and table.find(allowedbrainrots,obj:GetAttribute("Index")) then

						else
							if table.find(allowedbrainrots,obj.Name) and obj:IsA("Model") and obj:FindFirstChild("RootPart") then

							else
								local p = getPosition(obj)
								if p then
									if (p - pos).Magnitude > RANGE  then
										stored[obj] = getCFrame(obj)
										obj.Parent = Lighting
									end
								end
							end
						end
					end
				end
				for _, obj in ipairs(Lighting:GetChildren()) do
					if stored[obj] then
						local p = getPosition(obj)
						if p and (p - pos).Magnitude <= RANGE then
							obj.Parent = Workspace
							task.wait()

							setCFrame(obj, stored[obj])
							stored[obj] = nil
						end
					end
				end
			end

			while true do
				update()
				task.wait(UPDATE_RATE)
			end
		end
	end)
