	local function fastTeleportTo(rtq)
		local targetPosz = rtq.Pos
		local character = game.Players.LocalPlayer.Character
		local rootPart = character.HumanoidRootPart

		local attempts = 0
		local reached = false

		while attempts < 5 and not reached do
			attempts = attempts + 1

			if os.clock() - lastCompute < COOLDOWN then 
				task.wait(COOLDOWN) 
			end
			lastCompute = os.clock()

			local success = pcall(function()
				path:ComputeAsync(rootPart.Position, targetPosz.Position)
			end)

			if success and path.Status == Enum.PathStatus.Success then
				local waypoints = path:GetWaypoints()
				local rayParams = RaycastParams.new()
				rayParams.FilterDescendantsInstances = {character}
				rayParams.FilterType = Enum.RaycastFilterType.Exclude

				local i = 1
					while i < #waypoints do
					local jumpTo = i + 1

					local maxSkip = math.max(i + 1, #waypoints - ((attempts - 1) * 4))

					for j = maxSkip, i + 1, -1 do
						local startP = waypoints[i].Position + Vector3.new(0, 2, 0)
						local endP = waypoints[j].Position + Vector3.new(0, 2, 0)

						if not workspace:Raycast(startP, endP - startP, rayParams) then
							jumpTo = j
							break
						end
					end

					local targetWP = waypoints[jumpTo]
					if (rootPart.Position - targetWP.Position).Magnitude < 13.5 then
						task.wait(0.05)
					end

					rootPart.CFrame = CFrame.new(targetWP.Position + Vector3.new(0, 3.5, 0))
					i = jumpTo
				end
			else
				rootPart.CFrame = CFrame.new(targetPosz.Position + Vector3.new(0, 5, 0))
			end

			task.wait(0.3)
			if (rootPart.Position - targetPosz.Position).Magnitude < 7 then
				reached = true
			end
		end

		if reached then
			if rtq.Jump then
				task.wait(0.2)
				rootPart.AssemblyLinearVelocity = Vector3.new(0, rtq.Jump * 5.5, 0)
				task.wait(0.3)
				rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			end

			if rtq.Main then
				rootPart.CFrame = rtq.Main
			end
		end
	end
